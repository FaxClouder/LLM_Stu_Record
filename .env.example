OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llm-stu-record
LANGSMITH_ENDPOINT=

# Shared defaults for LangChain learning projects
LANGCHAIN_PROVIDER=deepseek
LANGCHAIN_CHAT_MODEL=deepseek-v4-flash
LANGCHAIN_EMBEDDING_MODEL=text-embedding-3-small
LANGCHAIN_COMPARE_MODELS=
TAVILY_API_KEY=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small

# Alibaba Cloud Bailian / DashScope (OpenAI-compatible)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://<YOUR_WORKSPACE_ID>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Optional extras for dive-into-langgraph/app
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AMAP_API_KEY=
OPENSEARCH_SERVICE_ID=ops-web-search-001
OPENSEARCH_WORKSPACE_NAME=default
OPENSEARCH_HOST=
OPENSEARCH_API_KEY=
