OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llm-stu-record
LANGSMITH_ENDPOINT=

# Shared defaults for LangChain learning projects
LANGCHAIN_PROVIDER=deepseek
LANGCHAIN_CHAT_MODEL=deepseek-v4-flash
LANGCHAIN_EMBEDDING_MODEL=text-embedding-3-small
LANGCHAIN_COMPARE_MODELS=
TAVILY_API_KEY=

# Compatibility aliases used by cloned learning projects. Keep them in this
# root file instead of creating per-project .env files.
AI_API_KEY=
AI_ENDPOINT=
AI_MODEL=
AI_EMBEDDING_MODEL=
AI_COMPARE_MODELS=

# Common Agent / Hello-Agents examples
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_MODEL=
LLM_TIMEOUT=300
BACKEND_PORT=8000

# Dive into LangGraph overrides. Leave blank to use LANGCHAIN_* or provider defaults.
DIVE_PROVIDER=
DIVE_APP_PROVIDER=
DIVE_CHAT_MODEL=
DIVE_EMBEDDING_MODEL=
DIVE_ADVANCED_CHAT_MODEL=
DIVE_PARALLEL_CHAT_MODEL=
DIVE_RAG_CHAT_MODEL=
DIVE_WEB_SEARCH_CHAT_MODEL=
DIVE_DEEP_AGENTS_CHAT_MODEL=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small

# Alibaba Cloud Bailian / DashScope (OpenAI-compatible)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://<YOUR_WORKSPACE_ID>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Optional extras for dive-into-langgraph/app
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=deepseek-v3-2-251201
OLLAMA_BASE_URL=http://127.0.0.1:11435/v1
OLLAMA_MODEL=qwen3:4b
OLLAMA_API_KEY=-
AMAP_API_KEY=
OPENSEARCH_SERVICE_ID=ops-web-search-001
OPENSEARCH_WORKSPACE_NAME=default
OPENSEARCH_HOST=
OPENSEARCH_API_KEY=

# Optional RAG-Techniques providers
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
COHERE_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
CONTEXTUAL_API_KEY=
MILVUS_TOKEN=
HF_TOKEN=
