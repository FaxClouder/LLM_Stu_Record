# 复制为 .env 后填写。不要提交真实密钥。

# OpenAI 或 OpenAI 兼容服务
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI（仅 Microsoft GraphRAG 等案例需要）
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21

# 可选服务
COHERE_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
CONTEXTUAL_API_KEY=
CONTEXTUAL_BASE_URL=https://api.contextual.ai/v1
OLLAMA_BASE_URL=http://localhost:11434

# 可选数据库
MILVUS_URI=./artifacts/milvus.db
MILVUS_TOKEN=

# 环境变量可覆盖 config/models.toml 中的非敏感配置
RAG_CHAT_MODEL=
RAG_EMBEDDING_MODEL=
RAG_EVALUATION_MODEL=
RAG_TEMPERATURE=
RAG_MAX_TOKENS=
GROQ_FAST_MODEL=
GROQ_LARGE_MODEL=
GOOGLE_CHAT_MODEL=
COHERE_CHAT_MODEL=
COHERE_EMBEDDING_MODEL=
COHERE_RERANK_MODEL=
OLLAMA_EMBEDDING_MODEL=
SENTENCE_TRANSFORMER_MODEL=
CROSS_ENCODER_MODEL=
CONTEXTUAL_RERANK_MODEL=
